{
  "name": "Homework",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "class": {
      "type": "string"
    },
    "section": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "assigned_by": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Completed"
      ],
      "default": "Active"
    }
  },
  "required": [
    "title",
    "class",
    "subject",
    "due_date"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "$or": [
          {
            "role": "admin"
          },
          {
            "role": "user"
          }
        ]
      }
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}