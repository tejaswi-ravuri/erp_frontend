{
  "name": "Staff",
  "type": "object",
  "properties": {
    "staff_id": {
      "type": "string"
    },
    "full_name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "Teacher",
        "Admin",
        "Support"
      ]
    },
    "subject_taught": {
      "type": "string"
    },
    "qualification": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "joining_date": {
      "type": "string",
      "format": "date"
    },
    "salary": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Inactive"
      ],
      "default": "Active"
    }
  },
  "required": [
    "full_name",
    "role"
  ]
}